{
	"name": "phpgt/servicecontainer",
	"description": "Centralised container of a project's core objects.",
	"license": "MIT",

	"require": {
		"php": ">=8.3",
		"psr/container": "^2.0.1"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^12.4",
		"phpmd/phpmd": "^2.15",
		"squizlabs/php_codesniffer": "^4.0"
	},

	"provide": {
		"psr/container-implementation": "1.0"
	},

	"autoload": {
		"psr-4": {
			"Gt\\ServiceContainer\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Gt\\ServiceContainer\\Test\\": "./test/phpunit"
		}
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
